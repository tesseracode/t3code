+/**
+ * CopilotAdapterLive - GitHub Copilot provider adapter layer.
+ *
+ * Implements the ProviderAdapterShape contract for GitHub Copilot.
+ * Uses @github/copilot-sdk for session management and command execution.
+ *
+ * NOTE: This is a Phase 1 stub. `sendTurn` and interactive methods are
+ * not yet implemented — they will be filled in when the full SDK
+ * event-mapping layer is built.
+ *
+ * @module CopilotAdapterLive
+ */
+import type {
+  ApprovalRequestId,
+  ProviderApprovalDecision,
+  ProviderKind,
+  ProviderRuntimeEvent,
+  ProviderSendTurnInput,
+  ProviderSession,
+  ProviderSessionStartInput,
+  ProviderUserInputAnswers,
+  ThreadId,
+  TurnId,
+} from "@t3tools/contracts";
+import { Effect, Layer, Queue, Stream } from "effect";
+
+import {
+  ProviderAdapterRequestError,
+  ProviderAdapterSessionNotFoundError,
+  type ProviderAdapterError,
+} from "../Errors.ts";
+import { CopilotAdapter, type CopilotAdapterShape } from "../Services/CopilotAdapter.ts";
+import type {
+  ProviderAdapterCapabilities,
+  ProviderThreadSnapshot,
+} from "../Services/ProviderAdapter.ts";
+
+const PROVIDER: ProviderKind = "copilot";
+
+const CAPABILITIES: ProviderAdapterCapabilities = {
+  sessionModelSwitch: "restart-session",
+};
+
+interface CopilotSession {
+  readonly session: ProviderSession;
+  readonly turns: Array<{ id: TurnId; items: unknown[] }>;
+}
+
+export const CopilotAdapterLive = Layer.effect(
+  CopilotAdapter,
+  Effect.gen(function* () {
+    const sessions = new Map<string, CopilotSession>();
+    const eventQueue = yield* Queue.unbounded<ProviderRuntimeEvent>();
+
+    const notImplemented = (method: string) =>
+      Effect.fail(
+        new ProviderAdapterRequestError({
+          provider: PROVIDER,
+          method,
+          detail: "Copilot adapter: not yet implemented (Phase 1 stub)",
+        }),
+      );
+
+    const adapter: CopilotAdapterShape = {
+      provider: PROVIDER,
+      capabilities: CAPABILITIES,
+
+      startSession: (input: ProviderSessionStartInput) =>
+        Effect.gen(function* () {
+          const now = new Date().toISOString();
+          const session: ProviderSession = {
+            provider: PROVIDER,
+            status: "ready",
+            runtimeMode: input.runtimeMode,
+            cwd: input.cwd,
+            model: input.modelSelection?.model,
+            threadId: input.threadId,
+            createdAt: now,
+            updatedAt: now,
+          };
+          sessions.set(input.threadId, { session, turns: [] });
+
+          yield* Queue.offer(eventQueue, {
+            _tag: "SessionStarted",
+            provider: PROVIDER,
+            threadId: input.threadId,
+            timestamp: now,
+          } as unknown as ProviderRuntimeEvent);
+
+          return session;
+        }),
+
+      sendTurn: (_input) => notImplemented("sendTurn") as any,
+
+      interruptTurn: (_threadId, _turnId) =>
+        notImplemented("interruptTurn") as any,
+
+      respondToRequest: (_threadId, _requestId, _decision) =>
+        notImplemented("respondToRequest") as any,
+
+      respondToUserInput: (_threadId, _requestId, _answers) =>
+        notImplemented("respondToUserInput") as any,
+
+      stopSession: (threadId) =>
+        Effect.sync(() => {
+          sessions.delete(threadId);
+        }),
+
+      listSessions: () =>
+        Effect.sync(() =>
+          Array.from(sessions.values()).map((s) => s.session),
+        ),
+
+      hasSession: (threadId) =>
+        Effect.sync(() => sessions.has(threadId)),
+
+      readThread: (threadId) =>
+        Effect.gen(function* () {
+          const entry = sessions.get(threadId);
+          if (!entry) {
+            return yield* Effect.fail(
+              new ProviderAdapterSessionNotFoundError({
+                provider: PROVIDER,
+                threadId,
+              }),
+            );
+          }
+          return {
+            threadId,
+            turns: entry.turns,
+          } satisfies ProviderThreadSnapshot;
+        }),
+
+      rollbackThread: (_threadId, _numTurns) =>
+        notImplemented("rollbackThread") as any,
+
+      stopAll: () =>
+        Effect.sync(() => {
+          sessions.clear();
+        }),
+
+      streamEvents: Stream.fromQueue(eventQueue),
+    };
+
+    return adapter;
+  }),
+);
diff --git a/apps/server/src/provider/Layers/CopilotProvider.ts b/apps/server/src/provider/Layers/CopilotProvider.ts
