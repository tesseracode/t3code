diff --git a/apps/web/src/index.css b/apps/web/src/index.css
index 6a4db398..fcc39ebb 100644
--- a/apps/web/src/index.css
+++ b/apps/web/src/index.css
@@ -534,3 +534,45 @@ label:has(> select#reasoning-effort) select {
   -webkit-background-clip: text;
   animation: ultrathink-rainbow 10s linear infinite;
 }
+
+/* ── xhigh effort theming (GPT/Copilot Extra High) ─────────────── */
+
+@keyframes xhigh-pulse {
+  0% {
+    background-position: 0% 50%;
+  }
+  100% {
+    background-position: 200% 50%;
+  }
+}
+
+@keyframes xhigh-glow {
+  0% {
+    filter: hue-rotate(140deg) saturate(1.4) brightness(1.1);
+  }
+  50% {
+    filter: hue-rotate(180deg) saturate(1.6) brightness(1.3);
+  }
+  100% {
+    filter: hue-rotate(140deg) saturate(1.4) brightness(1.1);
+  }
+}
+
+.xhigh-frame {
+  --xhigh-spectrum: linear-gradient(
+    120deg,
+    #0ea5e9 0%,
+    #06b6d4 20%,
+    #14b8a6 40%,
+    #10b981 60%,
+    #06b6d4 80%,
+    #0ea5e9 100%
+  );
+  background-image: var(--xhigh-spectrum);
+  background-size: 220% 220%;
+  animation: xhigh-pulse 8s linear infinite;
+}
+
+.xhigh-chroma {
+  animation: xhigh-glow 4s ease-in-out infinite;
+}
