+ * CopilotAdapter - Service tag for GitHub Copilot provider adapter operations.
+ */
+export class CopilotAdapter extends Context.Service<CopilotAdapter, CopilotAdapterShape>()(
+  "t3/provider/Services/CopilotAdapter",
